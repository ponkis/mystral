<UserControl x:Class="Mystral.Controls.JewelCasePreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Cursor="Hand"
             Focusable="False"
             ToolTip="Upload cover"
             MouseEnter="Preview_MouseEnter"
             MouseLeave="Preview_MouseLeave"
             LostMouseCapture="Preview_LostMouseCapture"
             PreviewMouseLeftButtonDown="Preview_PreviewMouseLeftButtonDown"
             PreviewMouseLeftButtonUp="Preview_PreviewMouseLeftButtonUp">
    <Grid Background="Transparent">
        <Image x:Name="CaseImage"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <Border x:Name="UploadHint"
                Opacity="0"
                IsHitTestVisible="False"
                Background="#72000000">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="22"
                       Foreground="White"
                       Text="&#xE898;" />
        </Border>
    </Grid>
</UserControl>
