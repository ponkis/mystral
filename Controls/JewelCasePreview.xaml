<UserControl x:Class="Mystral.Controls.JewelCasePreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Cursor="Hand"
             Focusable="False"
             ToolTip="Upload cover"
             MouseEnter="Preview_MouseEnter"
             MouseLeave="Preview_MouseLeave"
             LostMouseCapture="Preview_LostMouseCapture"
             PreviewMouseLeftButtonDown="Preview_PreviewMouseLeftButtonDown"
             PreviewMouseLeftButtonUp="Preview_PreviewMouseLeftButtonUp">
    <Grid Background="Transparent">
        <Image x:Name="CaseImage"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <Border x:Name="UploadHint"
                Opacity="0"
                IsHitTestVisible="False"
                Background="#72000000">
            <Border Width="26"
                    Height="26"
                    CornerRadius="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    Background="#6F1A2023">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="#F7FAF7"
                           Text="&#xE898;" />
            </Border>
        </Border>
    </Grid>
</UserControl>
