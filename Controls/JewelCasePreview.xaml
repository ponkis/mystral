<UserControl x:Class="Mystral.Controls.JewelCasePreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Cursor="Hand"
             Focusable="False"
             ToolTip="Upload cover"
             MouseEnter="Preview_MouseEnter"
             MouseLeave="Preview_MouseLeave"
             LostMouseCapture="Preview_LostMouseCapture"
             PreviewMouseLeftButtonDown="Preview_PreviewMouseLeftButtonDown"
             PreviewMouseLeftButtonUp="Preview_PreviewMouseLeftButtonUp">
    <Border BorderBrush="#D7EFF7F7"
            BorderThickness="1"
            Background="#22303336"
            ClipToBounds="True">
        <Grid Background="Transparent">
            <Border IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#D9F5FAFA" Offset="0" />
                        <GradientStop Color="#7A7E8F96" Offset="0.48" />
                        <GradientStop Color="#86242A2E" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Image x:Name="CaseImage"
                   Stretch="Fill"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Rectangle Height="64"
                       VerticalAlignment="Top"
                       Opacity="0.38"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border x:Name="UploadHint"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Background="#72000000">
                <Border Width="52"
                        Height="52"
                        CornerRadius="9"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        BorderBrush="#80FFFFFF"
                        BorderThickness="1"
                        Background="#6F1A2023">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="26"
                               Foreground="#F7FAF7"
                               Text="&#xE898;" />
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
