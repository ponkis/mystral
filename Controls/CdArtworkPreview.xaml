<UserControl x:Class="Mystral.Controls.CdArtworkPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Cursor="Hand"
             Focusable="False"
             ToolTip="Upload CD artwork"
             MouseEnter="Preview_MouseEnter"
             MouseLeave="Preview_MouseLeave"
             PreviewMouseLeftButtonDown="Preview_PreviewMouseLeftButtonDown"
             PreviewMouseLeftButtonUp="Preview_PreviewMouseLeftButtonUp"
             LostMouseCapture="Preview_LostMouseCapture">
    <Grid Background="Transparent">
        <Image Width="120"
               Height="120"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Source="{Binding ComposedArtwork, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <RotateTransform x:Name="DiscRotation" />
            </Image.RenderTransform>
        </Image>
    </Grid>
</UserControl>
