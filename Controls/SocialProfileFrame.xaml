<UserControl x:Class="Mystral.Controls.SocialProfileFrame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="139"
             Height="139"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid Width="139"
          Height="139">
        <Grid Width="96"
              Height="96"
              Margin="24,19,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              ClipToBounds="True">
            <Image x:Name="ProfilePictureImage"
                   Width="96"
                   Height="96"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Grid>

        <Canvas Width="139"
                Height="139"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                ClipToBounds="True">
            <Image x:Name="BackFrameImage"
                   Canvas.Left="0"
                   Canvas.Top="0"
                   Height="139"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Stretch="None"
                   SnapsToDevicePixels="True">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="BackFrameTranslate" />
                </Image.RenderTransform>
            </Image>
        </Canvas>

        <Canvas Width="139"
                Height="139"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                ClipToBounds="True">
            <Image x:Name="FrontFrameImage"
                   Canvas.Left="0"
                   Canvas.Top="0"
                   Height="139"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Stretch="None"
                   SnapsToDevicePixels="True">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="FrontFrameTranslate" />
                </Image.RenderTransform>
            </Image>
        </Canvas>
    </Grid>
</UserControl>
