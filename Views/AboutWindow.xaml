<Window x:Class="Mystral.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Mystral"
        Width="386"
        Height="138"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="22"
                          ShadowDepth="0"
                          Opacity="0.48"
                          Color="#070A0C" />

        <DropShadowEffect x:Key="TextShadow"
                          BlurRadius="2"
                          ShadowDepth="1"
                          Opacity="0.5"
                          Color="#000000" />

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#F3F7F4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#3CFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#52000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="RootCard"
            CornerRadius="9"
            BorderBrush="#A9E2EEF2"
            BorderThickness="1"
            Effect="{StaticResource CardShadow}"
            SizeChanged="RootCard_SizeChanged">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#D65E686C" Offset="0" />
                <GradientStop Color="#C7323A40" Offset="0.25" />
                <GradientStop Color="#D0151A1F" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid ClipToBounds="True">
            <Rectangle Height="82"
                       VerticalAlignment="Top"
                       Opacity="0.62"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                        <GradientStop Color="#57FFFFFF" Offset="0.42" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border Margin="1"
                    CornerRadius="8"
                    BorderBrush="#36FFFFFF"
                    BorderThickness="1"
                    IsHitTestVisible="False" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Margin="10,0,70,0"
                               VerticalAlignment="Center"
                               Foreground="#E9F5F0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="About"
                               Effect="{StaticResource TextShadow}" />
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource ChromeButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Path Width="11"
                              Height="11"
                              Stretch="Uniform"
                              Stroke="#F7FAF7"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 1,1 L 10,10 M 10,1 L 1,10" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="24,16,26,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Image x:Name="AppLogoImage"
                           Grid.Column="0"
                           Width="80"
                           Height="80"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Top">
                        <TextBlock x:Name="TitleText"
                                   Foreground="#FBFCF7"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Effect="{StaticResource TextShadow}" />

                        <TextBlock Margin="0,7,0,0"
                                   Foreground="#D4E2DC"
                                   FontSize="13"
                                   Effect="{StaticResource TextShadow}">
                            <Run Text="Made with love by " />
                            <Hyperlink NavigateUri="https://ponkis.xyz/"
                                       RequestNavigate="Hyperlink_RequestNavigate"
                                       Foreground="#D4E2DC">
                                <Bold><Run Text="ponkis" /></Bold>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
