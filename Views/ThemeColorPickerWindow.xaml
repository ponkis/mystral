<Window x:Class="Mystral.Views.ThemeColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:picker="clr-namespace:ColorPicker;assembly=ColorPicker"
        Title="Choose player theme"
        Icon="pack://siteoforigin:,,,/Resources/appearance.ico"
        Width="300"
        Height="426"
        MinWidth="300"
        MinHeight="426"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F0F0F0"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PresentationFramework.Aero;component/themes/Aero.NormalColor.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Foreground="#333333"
                   TextWrapping="Wrap"
                   Text="Choose a color." />

        <picker:SquarePicker x:Name="ThemeColorPicker"
                             Grid.Row="1"
                             Margin="0,12"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch" />

        <picker:HexColorTextBox Grid.Row="2"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Center"
                                ShowAlpha="False"
                                ColorState="{Binding ColorState, ElementName=ThemeColorPicker, Mode=TwoWay}" />

        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="82"
                    Height="24"
                    Margin="0,0,7,0"
                    IsDefault="True"
                    Click="UseColorButton_Click"
                    Content="Use color" />
            <Button Width="72"
                    Height="24"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
