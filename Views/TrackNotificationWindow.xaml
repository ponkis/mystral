<Window x:Class="Mystral.Views.TrackNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mystral" Height="120" Width="239"
        AllowsTransparency="True" WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        UseLayoutRounding="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="22"
                          ShadowDepth="0"
                          Opacity="0.48"
                          Color="#070A0C" />
        <DropShadowEffect x:Key="TextShadow"
                          BlurRadius="2"
                          ShadowDepth="1"
                          Opacity="0.5"
                          Color="#000000" />
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#F3F7F4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#3CFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#52000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootCard"
            CornerRadius="9"
            BorderBrush="#A9E2EEF2"
            BorderThickness="1"
            Effect="{StaticResource CardShadow}">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop x:Name="CardTopStop" Color="#905C686E" Offset="0" />
                <GradientStop x:Name="CardUpperStop" Color="#82475258" Offset="0.21" />
                <GradientStop x:Name="CardLowerStop" Color="#762D363B" Offset="0.53" />
                <GradientStop x:Name="CardBottomStop" Color="#84394449" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid x:Name="GlassSurface" ClipToBounds="True" SizeChanged="RoundedSurface_SizeChanged">
            <Grid.Background>
                <RadialGradientBrush Center="0.8,1.12"
                                     GradientOrigin="0.72,0.96"
                                     RadiusX="0.84"
                                     RadiusY="0.72">
                    <GradientStop x:Name="GlowPrimaryStop" Color="#76E6F4FA" Offset="0" />
                    <GradientStop x:Name="GlowSecondaryStop" Color="#1C8496A0" Offset="0.45" />
                    <GradientStop Color="#00000000" Offset="1" />
                </RadialGradientBrush>
            </Grid.Background>

            <!-- Inner subtle white border -->
            <Border Margin="1"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#2BFFFFFF"
                    IsHitTestVisible="False" />

            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header/Titlebar -->
                <Grid Grid.Row="0">
                    <Button HorizontalAlignment="Left"
                            Style="{StaticResource ChromeButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Path Width="8"
                              Height="8"
                              Stretch="Uniform"
                              Stroke="#F7FAF7"
                              StrokeThickness="1.8"
                              Data="M 1,1 L 10,10 M 10,1 L 1,10" />
                    </Button>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                IsHitTestVisible="False">
                        <Image Width="16"
                               Height="16"
                               VerticalAlignment="Center"
                               Source="pack://siteoforigin:,,,/Resources/ico.ico"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="Mystral"
                                   Foreground="#FBFCF7"
                                   FontWeight="SemiBold"
                                   FontSize="11.5"
                                   Effect="{StaticResource TextShadow}" />
                    </StackPanel>
                </Grid>

                <!-- Main Content Area -->
                <Grid Grid.Row="1" Margin="4,6,4,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="66" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Cover Art Glossy Border Container -->
                    <Border Grid.Column="0"
                            Width="66"
                            Height="66"
                            CornerRadius="5"
                            BorderBrush="#D7EFF7F7"
                            BorderThickness="1"
                            Background="#22303336"
                            VerticalAlignment="Center"
                            ClipToBounds="True">
                        <Grid x:Name="CoverArtGrid" SizeChanged="RoundedSurface_SizeChanged">
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#D9F5FAFA" Offset="0" />
                                        <GradientStop Color="#7A7E8F96" Offset="0.48" />
                                        <GradientStop Color="#86242A2E" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Image x:Name="ArtPlaceholder"
                                   Source="pack://siteoforigin:,,,/Resources/Images/unknown.png"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <Image x:Name="ArtImage"
                                   Stretch="UniformToFill" />
                            <!-- Top Gloss Crease Overlay -->
                            <Rectangle Height="30"
                                       VerticalAlignment="Top"
                                       Opacity="0.38"
                                       IsHitTestVisible="False">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </Border>

                    <!-- Text Metadata -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="TrackTitleText"
                                   Foreground="#FBFCF7"
                                   FontSize="13.5"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   Effect="{StaticResource TextShadow}"
                                   Text="Song Title" />
                        <TextBlock x:Name="TrackArtistText"
                                   Margin="0,3,0,0"
                                   Foreground="#EAF1EA"
                                   FontSize="11.5"
                                   FontWeight="Regular"
                                   TextTrimming="CharacterEllipsis"
                                   Effect="{StaticResource TextShadow}"
                                   Text="Artist Name" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
