<Window x:Class="Mystral.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Mystral.Controls"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        Title="Settings"
        Icon="pack://siteoforigin:,,,/Resources/settings.ico"
        Width="520"
        Height="430"
        MinWidth="520"
        MinHeight="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F0F0F0"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PresentationFramework.Aero;component/themes/Aero.NormalColor.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="CategoryListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Padding" Value="5,1" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3399FF" />
                                    <Setter TargetName="Bd" Property="TextElement.Foreground" Value="White" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#DCEBFC" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True" />
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="#3399FF" />
                                    <Setter TargetName="Bd" Property="TextElement.Foreground" Value="White" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SettingTextBoxStyle" TargetType="{x:Type TextBox}">
                <Setter Property="Width" Value="245" />
                <Setter Property="Height" Value="22" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Foreground" Value="#333333" />
            </Style>

            <Style x:Key="SettingPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
                <Setter Property="Width" Value="245" />
                <Setter Property="Height" Value="22" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Foreground" Value="#333333" />
            </Style>

            <ContextMenu x:Key="HistoryItemContextMenu">
                <MenuItem Header="Remove" Click="RemoveHistoryItem_Click">
                    <MenuItem.Icon>
                        <Image Width="16"
                               Height="16"
                               Source="pack://siteoforigin:,,,/Resources/delete.ico"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="92" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ListBox x:Name="CategoriesListBox"
                 BorderBrush="#7F9DB9"
                 ItemContainerStyle="{StaticResource CategoryListBoxItemStyle}"
                 SelectionChanged="CategoriesListBox_SelectionChanged">
            <ListBoxItem x:Name="LastFmCategoryItem" Height="28" Content="Last.fm" />
            <ListBoxItem x:Name="BehaviorCategoryItem" Height="28" Content="Behavior" />
            <ListBoxItem x:Name="AppearanceCategoryItem" Height="28" Content="Appearance" />
            <ListBoxItem x:Name="SocialCategoryItem" Height="28" Content="Social" />
            <ListBoxItem x:Name="HistoryCategoryItem" Height="28" Content="History" />
        </ListBox>

        <Grid Grid.Column="1"
              Margin="8,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,12">
                <Image x:Name="SettingsHeaderIcon"
                       Width="16"
                       Height="16"
                       Margin="0,1,6,0"
                       VerticalAlignment="Top"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock x:Name="SettingsTitleText"
                           FontWeight="Bold"
                           Foreground="#111111"
                           Text="Settings" />
            </StackPanel>

            <Grid Grid.Row="1">
                <StackPanel x:Name="LastFmPanel">
                    <TextBlock FontWeight="Bold" Text="Last.fm" />
                    <TextBlock Margin="0,5,0,12"
                               Foreground="#555555"
                               TextWrapping="Wrap"
                               Text="Configure credentials used by Last.fm-dependent options." />

                    <CheckBox x:Name="EnableLastFmCheckBox"
                              Margin="0,0,0,12"
                              Content="Enable Last.fm integration"
                              Click="SettingsControl_Changed" />

                    <TextBlock Text="API key" IsEnabled="{Binding IsChecked, ElementName=EnableLastFmCheckBox}" />
                    <TextBox x:Name="ApiKeyBox"
                             Margin="0,4,0,10"
                             Style="{StaticResource SettingTextBoxStyle}"
                             TextChanged="SettingsControl_Changed"
                             IsEnabled="{Binding IsChecked, ElementName=EnableLastFmCheckBox}" />

                    <TextBlock Text="Username" IsEnabled="{Binding IsChecked, ElementName=EnableLastFmCheckBox}" />
                    <TextBox x:Name="UsernameBox"
                             Margin="0,4,0,10"
                             Style="{StaticResource SettingTextBoxStyle}"
                             TextChanged="SettingsControl_Changed"
                             IsEnabled="{Binding IsChecked, ElementName=EnableLastFmCheckBox}" />

                    <CheckBox x:Name="ScrobbleCheckBox"
                              Margin="0,2,0,10"
                              Content="Scrobble playback to Last.fm"
                              ToolTip="Scrobbling signs requests against your account, so it also needs the API secret and password below."
                              Click="SettingsControl_Changed"
                              IsEnabled="{Binding IsChecked, ElementName=EnableLastFmCheckBox}" />

                    <TextBlock x:Name="ApiSecretLabel" Text="API secret (scrobbling only)" />
                    <TextBox x:Name="ApiSecretBox"
                             Margin="0,4,0,10"
                             Style="{StaticResource SettingTextBoxStyle}"
                             TextChanged="SettingsControl_Changed" />

                    <TextBlock x:Name="PasswordLabel" Text="Password (scrobbling only)" />
                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,4,0,10"
                                 Style="{StaticResource SettingPasswordBoxStyle}"
                                 PasswordChanged="SettingsControl_Changed" />

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image x:Name="StatusIcon"
                               Width="16"
                               Height="16"
                               Margin="0,0,6,0"
                               VerticalAlignment="Top"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock x:Name="LastFmStatusText"
                                   Grid.Column="1"
                                   Foreground="#555555"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="BehaviorPanel"
                             Visibility="Collapsed">
                    <TextBlock FontWeight="Bold" Text="Behavior" />
                    <CheckBox x:Name="CloseToTrayCheckBox"
                              Margin="0,12,0,0"
                              Content="Show in tray when closing"
                              Click="SettingsControl_Changed" />
                    <CheckBox x:Name="EnableNotificationsCheckBox"
                              Margin="0,8,0,0"
                              Content="Enable notifications"
                              Click="SettingsControl_Changed" />
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Margin="0,8,0,0"
                              Content="Start Mystral with Windows"
                              Click="SettingsControl_Changed" />
                    <CheckBox x:Name="CheckForUpdatesOnStartupCheckBox"
                              Margin="0,8,0,0"
                              Content="Check for updates on startup"
                              Click="SettingsControl_Changed" />
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="Bold"
                               Text="Burn lyrics" />
                    <TextBlock Margin="0,7,0,4"
                               Text="Lyrics provider" />
                    <ComboBox x:Name="BurnLyricsProviderComboBox"
                              Width="245"
                              Height="23"
                              HorizontalAlignment="Left"
                              SelectionChanged="SettingsControl_Changed">
                        <ComboBoxItem Content="MusicBrainz (default)" />
                        <ComboBoxItem Content="LRCLIB" />
                    </ComboBox>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#555555"
                               TextWrapping="Wrap"
                               Text="MusicBrainz looks up the song's official details first, which usually finds better lyrics. LRCLIB searches using exactly what's typed in the burn editor." />
                </StackPanel>

                <StackPanel x:Name="AppearancePanel"
                            Visibility="Collapsed">
                    <TextBlock FontWeight="Bold"
                               Text="Appearance" />
                    <TextBlock Margin="0,5,0,12"
                               Foreground="#555555"
                               TextWrapping="Wrap"
                               Text="Choose the player's color theme." />

                    <TextBlock Text="Theme" />
                    <ComboBox x:Name="PlayerThemeComboBox"
                              Width="245"
                              Height="23"
                              Margin="0,4,0,0"
                              HorizontalAlignment="Left"
                              SelectionChanged="PlayerThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Automatic" />
                        <ComboBoxItem Content="Custom color..." />
                    </ComboBox>

                    <StackPanel Margin="0,12,0,0"
                                Orientation="Horizontal">
                        <Border Width="24"
                                Height="24"
                                BorderBrush="#7F7F7F"
                                BorderThickness="1"
                                CornerRadius="2">
                            <Border x:Name="PlayerThemeColorSwatch"
                                    Margin="2"
                                    Background="#4A5258"
                                    CornerRadius="1" />
                        </Border>
                        <TextBlock x:Name="PlayerThemeColorText"
                                   Width="112"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#333333"
                                   Text="#4A5258" />
                        <Button x:Name="ChoosePlayerThemeColorButton"
                                Width="104"
                                Height="23"
                                Content="Choose color..."
                                Click="ChoosePlayerThemeColorButton_Click" />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="SocialPanel"
                            Visibility="Collapsed">
                    <TextBlock FontWeight="Bold"
                               Text="Link to globe" />
                    <TextBlock Margin="0,5,0,10"
                               Foreground="#555555"
                               TextWrapping="Wrap"
                               Text="Link your globe account to share your burned CDs with the world." />

                    <Border Height="103"
                            BorderBrush="#A8A8A8"
                            BorderThickness="1"
                            Background="White"
                            Cursor="Hand"
                            ToolTip="Visit chat.ponkis.xyz"
                            MouseLeftButtonUp="SocialAd_MouseLeftButtonUp">
                        <Image Stretch="Uniform"
                               gif:AnimationBehavior.SourceUri="pack://siteoforigin:,,,/Resources/Images/ad.gif"
                               gif:AnimationBehavior.AutoStart="True"
                               gif:AnimationBehavior.RepeatBehavior="Forever"
                               gif:AnimationBehavior.CacheFramesInMemory="False" />
                    </Border>

                    <CheckBox x:Name="AutomaticallyShareBurnsCheckBox"
                              Margin="0,8,0,0"
                              Content="Automatically share burned CDs to globe"
                              Click="SettingsControl_Changed" />

                    <Grid Height="112"
                          Margin="0,8,0,0">
                        <Grid x:Name="SocialProfileContent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Viewbox Width="112"
                                     Height="112"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     Stretch="Uniform">
                                <controls:SocialProfileFrame x:Name="SocialProfileFrame" />
                            </Viewbox>

                            <Grid x:Name="SocialProfileDetailsHost"
                                  Grid.Column="1"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center">
                                <StackPanel x:Name="UnlinkedSocialProfilePanel">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#111111"
                                               Text="Not signed in" />
                                    <TextBlock Margin="0,1,0,0"
                                               Foreground="#666666"
                                               Text="No account linked" />
                                    <TextBlock Margin="0,12,0,0">
                                        <Hyperlink Click="LinkSocialAccount_Click">link your account</Hyperlink>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel x:Name="LinkedSocialProfilePanel"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="SocialUsernameText"
                                               Foreground="#666666"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="SocialDisplayNameText"
                                               Margin="0,0,0,1"
                                               FontSize="20"
                                               Foreground="#111111"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="SocialCdCountText"
                                               Foreground="#666666"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,10,0,0">
                                        <Hyperlink x:Name="UnlinkSocialAccountLink"
                                                   Click="UnlinkSocialAccount_Click">unlink your account</Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <StackPanel x:Name="SocialSigningInPanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="SocialSigningInText"
                                       HorizontalAlignment="Center"
                                       FontSize="18"
                                       Foreground="#777777"
                                       Text="Signing in..." />
                            <Canvas Width="48"
                                    Height="36"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    ClipToBounds="True">
                                <Image Width="1536"
                                       Height="36"
                                       Source="pack://siteoforigin:,,,/Resources/Images/Speen.png"
                                       Stretch="None"
                                       SnapsToDevicePixels="True">
                                    <Image.RenderTransform>
                                        <TranslateTransform x:Name="SocialSigningInSpriteTranslate" />
                                    </Image.RenderTransform>
                                </Image>
                            </Canvas>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="HistoryPanel"
                            Visibility="Collapsed">
                    <TextBlock FontWeight="Bold" Text="Playback History" />
                    <TextBlock Margin="0,5,0,12"
                               Foreground="#555555"
                               TextWrapping="Wrap"
                               Text="View locally cached scrobbles and download them for manual upload." />

                    <Grid Margin="0,0,0,8">
                        <Button x:Name="RefreshHistoryButton"
                                Content="Refresh"
                                Width="64"
                                Height="22"
                                HorizontalAlignment="Left"
                                Click="RefreshHistoryButton_Click" />
                        <Button x:Name="ClearHistoryButton"
                                Content="Clear History"
                                Width="88"
                                Height="22"
                                HorizontalAlignment="Right"
                                IsEnabled="False"
                                Click="ClearHistoryButton_Click" />
                    </Grid>

                    <ListView x:Name="HistoryListView"
                              Height="180"
                              BorderThickness="1"
                              BorderBrush="#7F9DB9"
                              Background="White"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="ContextMenu" Value="{StaticResource HistoryItemContextMenu}" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="30">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="{x:Type GridViewColumnHeader}">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Title" Width="135" DisplayMemberBinding="{Binding Title}" />
                                <GridViewColumn Header="Artist" Width="110" DisplayMemberBinding="{Binding Artist}" />
                                <GridViewColumn Header="Time" Width="125" DisplayMemberBinding="{Binding FormattedTime}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button x:Name="ExportHistoryButton"
                            Content="Export Full History (CSV)"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            MinWidth="150"
                            Height="24"
                            IsEnabled="False"
                            Click="ExportHistoryButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2"
                  Margin="0,12,0,0">
                <TextBlock x:Name="DirtyStatusText"
                           VerticalAlignment="Center"
                           Foreground="#555555" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="SaveButton"
                            MinWidth="72"
                            Height="23"
                            Margin="0,0,6,0"
                            Click="SaveButton_Click"
                            Content="Save" />
                    <Button x:Name="CloseButton"
                            MinWidth="72"
                            Height="23"
                            Click="CloseButton_Click"
                            Content="Close" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
