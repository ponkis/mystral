                    </Grid>
                </Grid>
            </Border>
 
            <Border x:Name="FullscreenPanel"
                    Grid.RowSpan="3"
                    Background="Transparent"
                    Visibility="Collapsed"
                    Opacity="0"
                    Panel.ZIndex="50">
