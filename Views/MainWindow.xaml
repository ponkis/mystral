                      ClipToBounds="True">
                    
                    <!-- Solid Opaque Base to prevent desktop showing through -->
                    <Border Background="#FF0C0F12" />
                    
                    <!-- Background: blurred art + color overlay -->
                    <Image x:Name="FullscreenBlurredArtImage"
                           Stretch="UniformToFill"
                           Opacity="0.4"
                           RenderOptions.BitmapScalingMode="LowQuality">
                        <Image.CacheMode>
                            <BitmapCache RenderAtScale="1" />
                        </Image.CacheMode>
                        <Image.Effect>
                            <BlurEffect Radius="60" KernelType="Gaussian" />
                        </Image.Effect>
                    </Image>

                    <Border Opacity="0.8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="FullscreenTintTopStop" Color="#161A22" Offset="0" />
                                <GradientStop x:Name="FullscreenTintMidStop" Color="#0D1115" Offset="0.5" />
                                <GradientStop x:Name="FullscreenTintBottomStop" Color="#070A0C" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Subtle colored glow overlay -->
                    <Border Opacity="0.35">
                        <Border.Background>
                            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                                <GradientStop x:Name="FullscreenGlowStop" Color="#E6F4FA" Offset="0" />
                                <GradientStop Color="#00000000" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>



