                                    </Rectangle>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="4"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="LyricsTitleText"
                                           Foreground="#F8FBF7"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"
                                           Effect="{StaticResource TextShadow}"
