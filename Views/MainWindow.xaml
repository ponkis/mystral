                          Margin="80,80,80,60">
                        <Grid.ColumnDefinitions>
                            <!-- Column 0: Music Info (Album Art, title, controls) -->
                            <ColumnDefinition x:Name="FullscreenInfoColumn" Width="*" />
                            <!-- Column 1: Spacer (when lyrics are visible) -->
                            <ColumnDefinition x:Name="FullscreenSpacerColumn" Width="0" />
                            <!-- Column 2: Lyrics View -->
                            <ColumnDefinition x:Name="FullscreenLyricsColumn" Width="0" />
                        </Grid.ColumnDefinitions>

                        <!-- Music Info Pane -->
                        <Grid x:Name="FullscreenInfoPanel"
                              Grid.Column="0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                            <StackPanel x:Name="FullscreenInfoStack"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                
                                <!-- Large Rounded Album Art -->
                                 <Border x:Name="FullscreenArtBorder"
                                         Width="450"
                                         Height="450"
                                         CornerRadius="16"
                                         BorderBrush="#D7EFF7F7"
                                         BorderThickness="1"
                                         Background="#22303336"
                                         ClipToBounds="True"
                                         HorizontalAlignment="Center"
                                         Effect="{StaticResource CardShadow}"
                                         SizeChanged="FullscreenLayout_SizeChanged">
                                     <Grid SizeChanged="FullscreenArtGrid_SizeChanged">
                                         <!-- Gloss Background Underlay -->
                                         <Border IsHitTestVisible="False">
                                             <Border.Background>
                                                 <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                     <GradientStop Color="#D9F5FAFA" Offset="0" />
                                                     <GradientStop Color="#7A7E8F96" Offset="0.48" />
                                                     <GradientStop Color="#86242A2E" Offset="1" />
                                                 </LinearGradientBrush>
                                             </Border.Background>
                                         </Border>
                                         
                                         <Image x:Name="FullscreenArtPlaceholder"
                                                Source="pack://siteoforigin:,,,/Resources/Images/unknown.png"
                                                Stretch="UniformToFill"
                                                RenderOptions.BitmapScalingMode="HighQuality" />
                                         <Image x:Name="FullscreenArtImage"
                                                Stretch="UniformToFill"
                                                RenderOptions.BitmapScalingMode="HighQuality" />
                                         
                                         <!-- Gloss Foreground Overlay Reflection -->
                                         <Rectangle Height="200"
                                                    VerticalAlignment="Top"
                                                    Opacity="0.38"
                                                    IsHitTestVisible="False">
                                             <Rectangle.Fill>
                                                 <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                     <GradientStop Color="#FFFFFFFF" Offset="0" />
                                                     <GradientStop Color="#00FFFFFF" Offset="1" />
                                                 </LinearGradientBrush>
                                             </Rectangle.Fill>
                                         </Rectangle>
                                     </Grid>
                                 </Border>

                                <!-- Title, Artist/Album Info -->
                                <TextBlock x:Name="FullscreenTitleText"
                                           Margin="0,28,0,0"
                                           Foreground="#FBFCF7"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           MaxWidth="{Binding Width, ElementName=FullscreenArtBorder}"
                                           TextTrimming="CharacterEllipsis"
                                           Effect="{StaticResource TextShadow}"
                                           Text="No active track" />

                                <TextBlock x:Name="FullscreenArtistText"
                                           Margin="0,6,0,0"
                                           Foreground="#CCFFFFFF"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           MaxWidth="{Binding Width, ElementName=FullscreenArtBorder}"
                                           TextTrimming="CharacterEllipsis"
                                           Effect="{StaticResource TextShadow}"
                                           Text="Start playback in any media app" />

                                <!-- Progress Slider & Times -->
                                <Grid Margin="0,24,0,0" Width="{Binding Width, ElementName=FullscreenArtBorder}" HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="FullscreenElapsedText"
                                               Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Foreground="#CCFFFFFF"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Effect="{StaticResource TextShadow}"
                                               Text="0:00" />
                                    <Slider x:Name="FullscreenProgressSlider"
                                            Grid.Column="1"
                                            Margin="10,0"
                                            Style="{StaticResource TimelineSliderStyle}" />
                                    <TextBlock x:Name="FullscreenDurationText"
                                               Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Foreground="#CCFFFFFF"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Effect="{StaticResource TextShadow}"
                                               Text="-0:00" />
                                </Grid>

                                <!-- Playback Controls Row -->
                                <Grid Margin="0,24,0,0" Width="{Binding Width, ElementName=FullscreenArtBorder}" HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Volume Slider on Left of controls -->
                                    <Grid Grid.Column="0"
                                          Width="110"
                                          HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                            <Button x:Name="FullscreenVolumeButton"
                                                    Width="24"
                                                    Height="24"
                                                    Cursor="Hand"
                                                    Template="{StaticResource VolumeButtonTemplate}"
                                                    Click="VolumeButton_Click"
                                                    ToolTip="Mute" />
                                            <Slider x:Name="FullscreenVolumeSlider"
                                                    Width="80"
                                                    Margin="6,0,0,0"
                                                    Style="{StaticResource VolumeSliderStyle}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Transport buttons in center -->
                                    <Canvas Grid.Column="1"
                                            Width="108"
                                            Height="44"
                                            HorizontalAlignment="Center">
                                        <Button x:Name="FullscreenPreviousButton"
                                                Canvas.Left="0"
                                                Canvas.Top="9"
                                                Style="{StaticResource AeroPreviousButtonStyle}"
                                                Click="PreviousButton_Click"
                                                ToolTip="Previous" />

                                        <Button x:Name="FullscreenNextButton"
                                                Canvas.Left="67"
                                                Canvas.Top="9"
                                                Style="{StaticResource AeroNextButtonStyle}"
                                                Click="NextButton_Click"
                                                ToolTip="Next" />

                                        <Button x:Name="FullscreenPlayPauseButton"
                                                Canvas.Left="33"
                                                Canvas.Top="0"
                                                Style="{StaticResource AeroPlayPauseButtonStyle}"
                                                CommandParameter="Play"
                                                Click="PlayPauseButton_Click"
                                                ToolTip="Play or pause" />
                                    </Canvas>

                                    <!-- Right buttons: Lyrics Toggle and Last.fm Info -->
                                    <Grid Grid.Column="2"
                                          Width="110"
                                          HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right">
                                            <Button x:Name="FullscreenInfoButton"
                                                    Style="{StaticResource InfoButtonStyle}"
                                                    Width="32"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Click="InfoButton_Click"
                                                    ToolTip="More" />
                                            <Button x:Name="FullscreenLyricsToggle"
                                                    Style="{StaticResource LyricsButtonStyle}"
                                                    Width="32"
                                                    Height="32"
                                                    Margin="0"
                                                    Click="FullscreenLyricsToggle_Click"
                                                    ToolTip="Lyrics" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Scrollable Lyrics Pane on the right -->
                        <Grid x:Name="FullscreenLyricsPanel"
                              Grid.Column="2"
                              Visibility="Collapsed"
                              Opacity="0">

                            <ScrollViewer x:Name="FullscreenLyricsScrollViewer"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Hidden"
                                          CanContentScroll="False"
                                          PanningMode="VerticalOnly"
                                          PreviewMouseWheel="FullscreenLyricsViewport_PreviewMouseWheel"
                                          SizeChanged="FullscreenLayout_SizeChanged">
                                <StackPanel x:Name="FullscreenLyricsStackPanel"
                                            Margin="0"
                                            VerticalAlignment="Top" />
                            </ScrollViewer>

                            <!-- Lyrics Load/Error panel in fullscreen -->
                            <Border x:Name="FullscreenLyricsMessagePanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Padding="24,20"
                                    CornerRadius="12"
                                    BorderBrush="#34FFFFFF"
                                    BorderThickness="1"
                                    Background="#40000000">
                                <Grid HorizontalAlignment="Center" MinHeight="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Image x:Name="FullscreenLyricsLoadingIcon"
                                           Width="32"
                                           Height="32"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"
                                           Visibility="Collapsed"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Image x:Name="FullscreenLyricsWarningIcon"
                                           Width="16"
                                           Height="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="None"
                                           Source="pack://siteoforigin:,,,/Resources/Images/WarningIcon.png"
                                           Visibility="Collapsed"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor" />

                                    <TextBlock x:Name="FullscreenLyricsMessageText"
                                               Grid.Column="2"
                                               MaxWidth="350"
                                               VerticalAlignment="Center"
                                               Foreground="#E6F3EB"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Effect="{StaticResource TextShadow}"
                                               Text="Looking for lyrics" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
 
         </Grid>
    </Border>
</Window>
