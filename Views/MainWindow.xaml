                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                    <Button x:Name="LyricsVolumeButton"
                                            Width="22"
                                            Height="22"
                                            Cursor="Hand"
                                            Visibility="Collapsed"
                                            Template="{StaticResource VolumeButtonTemplate}"
                                            Click="VolumeButton_Click"
                                            ToolTip="Mute" />
                                    <Slider x:Name="LyricsVolumeSlider"
                                            Width="55"
                                            Margin="4,0,0,0"
                                            Style="{StaticResource VolumeSliderStyle}"
                                            Visibility="Collapsed" />
                                </StackPanel>

                                <Canvas Grid.Column="1"
                                        Width="108"
                                        Height="43"
                                        HorizontalAlignment="Center">
                                    <Button x:Name="LyricsPreviousButton"
                                            Canvas.Left="0"
                                            Canvas.Top="9"
                                            Panel.ZIndex="0"
                                            Style="{StaticResource AeroPreviousButtonStyle}"
                                            Click="PreviousButton_Click"
                                            ToolTip="Previous" />

                                    <Button x:Name="LyricsNextButton"
                                            Canvas.Left="67"
                                            Canvas.Top="9"
                                            Panel.ZIndex="0"
                                            Style="{StaticResource AeroNextButtonStyle}"
