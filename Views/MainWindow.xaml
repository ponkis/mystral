                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Hidden"
                                          CanContentScroll="False"
                                          PanningMode="VerticalOnly">
                                <StackPanel x:Name="LyricsStackPanel"
                                            Margin="0,10,0,132"
                                            VerticalAlignment="Top" />
