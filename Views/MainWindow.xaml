<Window x:Class="Mystral.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mystral"
        Icon="pack://siteoforigin:,,,/Resources/ico.ico"
        Width="352"
        Height="172"
        MinWidth="218"
        MinHeight="144"
        MaxWidth="430"
        MaxHeight="660"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="MainWindow_Loaded"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        StateChanged="Window_StateChanged"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="22"
                          ShadowDepth="0"
                          Opacity="0.45"
                          Color="#070A0C" />

        <DropShadowEffect x:Key="TextShadow"
                          BlurRadius="2"
                          ShadowDepth="1"
                          Opacity="0.45"
                          Color="#000000" />

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#F3F7F4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                CornerRadius="0"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#3CFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#52000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Foreground" Value="#F7FAF7" />
            <Setter Property="BorderBrush" Value="#7CDCE9EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonShell"
                                CornerRadius="22"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#74FFFFFF" Offset="0" />
                                    <GradientStop Color="#29FFFFFF" Offset="0.44" />
                                    <GradientStop Color="#21000000" Offset="0.45" />
                                    <GradientStop Color="#38000000" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Border Margin="1"
                                        CornerRadius="21"
                                        Opacity="0.65">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#68FFFFFF" Offset="0" />
                                            <GradientStop Color="#12FFFFFF" Offset="0.52" />
                                            <GradientStop Color="#00000000" Offset="0.53" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonShell" Property="BorderBrush" Value="#E7FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonShell" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonShell" Property="Opacity" Value="0.38" />
                                <Setter Property="Cursor" Value="No" />
                                <Setter Property="ForceCursor" Value="True" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
            <Setter Property="Content" Value="." />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Path Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Stroke="#F7FAF7"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 3,5 L 15,5 M 3,9 L 15,9 M 3,13 L 15,13" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LyricsButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
            <Setter Property="Content" Value="." />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Path Width="15"
                              Height="15"
                              Stretch="Uniform"
                              Stroke="#F7FAF7"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M 2,3.5 C 2,2.3 3,1.5 4.2,1.5 L 13.8,1.5 C 15,1.5 16,2.3 16,3.5 L 16,10.5 C 16,11.7 15,12.5 13.8,12.5 L 8.5,12.5 L 5,15 L 5.8,12.5 L 4.2,12.5 C 3,12.5 2,11.7 2,10.5 Z M 5,5.2 L 13,5.2 M 5,8 L 11,8" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="18" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="2"
                                    Margin="0,0,8,0"
                                    CornerRadius="1"
                                    Background="#CCCCCC"
                                    VerticalAlignment="Center" />
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsTabStop="False"
                                                  Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="2"
                                                        Margin="0,0,-8,0"
                                                        CornerRadius="1">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#7FC9FA" Offset="0" />
                                                            <GradientStop Color="#014CB6" Offset="0.5" />
                                                            <GradientStop Color="#619FF2" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsTabStop="False"
                                                  Command="Slider.IncreaseLarge"
                                                  Opacity="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="TimeThumb"
                                           Width="16"
                                           Height="9"
                                           Cursor="Hand">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Visibility" Value="Hidden" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Slider}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Image x:Name="ThumbImage"
                                                       Width="16"
                                                       Height="9"
                                                       Source="pack://siteoforigin:,,,/Resources/Images/seekhandle.png"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbImage" Property="Source" Value="pack://siteoforigin:,,,/Resources/Images/seekhandle_hover.png" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbImage" Property="Source" Value="pack://siteoforigin:,,,/Resources/Images/seekhandle_pressed.png" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="No" />
                                <Setter Property="ForceCursor" Value="True" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimelineSliderStyle" TargetType="Slider" BasedOn="{StaticResource GlassSliderStyle}">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Value" Value="0" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ProgressSlider_PreviewMouseLeftButtonDown" />
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ProgressSlider_PreviewMouseLeftButtonUp" />
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider" BasedOn="{StaticResource GlassSliderStyle}">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <EventSetter Event="ValueChanged" Handler="VolumeSlider_ValueChanged" />
        </Style>

        <ControlTemplate x:Key="VolumeButtonTemplate" TargetType="Button">
            <Image x:Name="VolumeIcon"
                   Source="pack://siteoforigin:,,,/Resources/Images/vol_mid.png"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </ControlTemplate>

        <Style x:Key="AeroTransportButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="No" />
                    <Setter Property="ForceCursor" Value="True" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AeroPreviousButtonStyle" TargetType="Button" BasedOn="{StaticResource AeroTransportButtonStyle}">
            <Setter Property="Width" Value="41" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Image x:Name="ButtonImage"
                               Source="pack://siteoforigin:,,,/Resources/Images/PreviewPrevButton.png"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://siteoforigin:,,,/Resources/Images/PreviewPrevButtonHover.png" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://siteoforigin:,,,/Resources/Images/PreviewPrevButtonPressed.png" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="No" />
                                <Setter Property="ForceCursor" Value="True" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AeroNextButtonStyle" TargetType="Button" BasedOn="{StaticResource AeroTransportButtonStyle}">
            <Setter Property="Width" Value="41" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Image x:Name="ButtonImage"
                               Source="pack://siteoforigin:,,,/Resources/Images/PreviewNextButton.png"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://siteoforigin:,,,/Resources/Images/PreviewNextButtonHover.png" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://siteoforigin:,,,/Resources/Images/PreviewNextButtonPressed.png" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="No" />
                                <Setter Property="ForceCursor" Value="True" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AeroPlayPauseButtonStyle" TargetType="Button" BasedOn="{StaticResource AeroTransportButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="43" />
            <Setter Property="Margin" Value="0" />
            <EventSetter Event="MouseEnter" Handler="PlayPauseButton_MouseEnter" />
            <EventSetter Event="MouseLeave" Handler="PlayPauseButton_MouseLeave" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="PlayPauseButton_PreviewMouseLeftButtonDown" />
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="PlayPauseButton_PreviewMouseLeftButtonUp" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Image x:Name="PlayPauseIcon"
                               Width="42"
                               Height="43"
                               Source="pack://siteoforigin:,,,/Resources/Images/play.png"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.72" />
                                <Setter Property="Cursor" Value="No" />
                                <Setter Property="ForceCursor" Value="True" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="RootCard"
            CornerRadius="9"
            BorderBrush="#A9E2EEF2"
            BorderThickness="1"
            Effect="{StaticResource CardShadow}"
            RenderTransformOrigin="0.5,0.5"
            SizeChanged="RoundedSurface_SizeChanged">
        <Border.RenderTransform>
            <ScaleTransform x:Name="WindowScale" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop x:Name="CardTopStop" Color="#905C686E" Offset="0" />
                <GradientStop x:Name="CardUpperStop" Color="#82475258" Offset="0.21" />
                <GradientStop x:Name="CardLowerStop" Color="#762D363B" Offset="0.53" />
                <GradientStop x:Name="CardBottomStop" Color="#84394449" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid x:Name="GlassSurface"
              ClipToBounds="True"
              SizeChanged="RoundedSurface_SizeChanged">
            <Grid.RowDefinitions>
                <RowDefinition Height="25" />
                <RowDefinition Height="88" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.Background>
                <RadialGradientBrush Center="0.8,1.12"
                                     GradientOrigin="0.72,0.96"
                                     RadiusX="0.84"
                                     RadiusY="0.72">
                    <GradientStop x:Name="GlowPrimaryStop" Color="#76E6F4FA" Offset="0" />
                    <GradientStop x:Name="GlowSecondaryStop" Color="#1C8496A0" Offset="0.45" />
                    <GradientStop Color="#00000000" Offset="1" />
                </RadialGradientBrush>
            </Grid.Background>

            <Image x:Name="BlurredArtImage"
                   Grid.RowSpan="3"
                   Stretch="UniformToFill"
                   Opacity="0.24"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapScalingMode="LowQuality">
                <Image.CacheMode>
                    <BitmapCache RenderAtScale="1" />
                </Image.CacheMode>
                <Image.Effect>
                    <BlurEffect Radius="18"
                                KernelType="Gaussian" />
                </Image.Effect>
            </Image>

            <Border Grid.RowSpan="3"
                    Opacity="0.20"
                    IsHitTestVisible="False">
                <Border.Background>
                    <RadialGradientBrush Center="0.82,0.12"
                                         GradientOrigin="0.82,0.12"
                                         RadiusX="0.95"
                                         RadiusY="0.9">
                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                        <GradientStop Color="#4DFFFFFF" Offset="0.22" />
                        <GradientStop Color="#00000000" Offset="0.72" />
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Rectangle Grid.RowSpan="3"
                       Height="66"
                       VerticalAlignment="Top"
                       Opacity="0.55">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#DBFFFFFF" Offset="0" />
                        <GradientStop Color="#58FFFFFF" Offset="0.38" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border x:Name="InnerGlassBorder"
                    Grid.RowSpan="3"
                    Margin="1"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#2BFFFFFF" />

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Panel.ZIndex="100"
                  Margin="0"
                  MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="ChromeButtons"
                            Grid.Column="1"
                            Orientation="Horizontal">
                    <Button x:Name="CollapseExpandedButton"
                            Style="{StaticResource ChromeButtonStyle}"
                            Click="CollapseExpandedButton_Click"
                            ToolTip="Collapse"
                            Visibility="Collapsed">
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 1,5 L 5,5 L 5,1 M 5,5 L 1,1 M 11,7 L 7,7 L 7,11 M 7,7 L 11,11" />
                    </Button>
                    <Button x:Name="TopmostButton"
                            Style="{StaticResource ChromeButtonStyle}"
                            Click="TopmostButton_Click"
                            ToolTip="Always on top">
                        <Path Width="11"
                              Height="11"
                              Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M 5,0 L 10,5 L 7,5 L 7,11 L 3,11 L 3,5 L 0,5 Z" />
                    </Button>
                    <Button x:Name="FullscreenButton"
                            Style="{StaticResource ChromeButtonStyle}"
                            Click="FullscreenButton_Click"
                            ToolTip="Fullscreen">
                        <Path x:Name="FullscreenButtonPath"
                              Width="11"
                              Height="11"
                              Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 1,6 L 1,1 L 6,1 M 1,1 L 7,7 M 14,9 L 14,14 L 9,14 M 14,14 L 8,8" />
                    </Button>
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource ChromeButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <Path Width="11"
                              Height="11"
                              Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.7"
                              Data="M 1,9 L 10,9" />
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource ChromeButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Path Width="11"
                              Height="11"
                              Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8"
                              Data="M 1,1 L 10,10 M 10,1 L 1,10" />
                    </Button>
                </StackPanel>
            </Grid>

            <Border x:Name="MediaPanel"
                    Grid.Row="1"
                    Margin="0,0,0,0"
                    BorderBrush="#57FFFFFF"
                    BorderThickness="0,1,0,1"
                    Background="#35000000">
                <Grid Margin="14,8,14,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="66" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="66"
                            Height="66"
                            CornerRadius="5"
                            BorderBrush="#D7EFF7F7"
                            BorderThickness="1"
                            Background="#22303336"
                            ClipToBounds="True">
                        <Grid x:Name="AlbumArtSurface"
                              MouseEnter="AlbumArt_MouseEnter"
                              MouseLeave="AlbumArt_MouseLeave"
                              MouseLeftButtonDown="AlbumArt_MouseLeftButtonDown"
                              MouseLeftButtonUp="AlbumArt_MouseLeftButtonUp"
                              SizeChanged="RoundedSurface_SizeChanged">
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#D9F5FAFA" Offset="0" />
                                        <GradientStop Color="#7A7E8F96" Offset="0.48" />
                                        <GradientStop Color="#86242A2E" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Image x:Name="ArtPlaceholderText"
                                   Source="pack://siteoforigin:,,,/Resources/Images/unknown.png"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <Image x:Name="ArtImage"
                                   Stretch="UniformToFill" />
                            <Rectangle Height="30"
                                       VerticalAlignment="Top"
                                       Opacity="0.38">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Border x:Name="AlbumExpandHint"
                                    Opacity="0"
                                    Background="#72000000"
                                    IsHitTestVisible="False">
                                <Border Width="26"
                                        Height="26"
                                        CornerRadius="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        BorderBrush="#80FFFFFF"
                                        BorderThickness="1"
                                        Background="#6F1A2023">
                                    <Path Width="13"
                                          Height="13"
                                          Stretch="Uniform"
                                          Stroke="#F7FAF7"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M 1,6 L 1,1 L 6,1 M 1,1 L 7,7 M 14,9 L 14,14 L 9,14 M 14,14 L 8,8" />
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TitleText"
                                   Grid.Row="0"
